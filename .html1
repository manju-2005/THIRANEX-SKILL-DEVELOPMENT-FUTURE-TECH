<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Website UI Redesign</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#f4f7fc;
    color:#333;
}

/* Navbar */
.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 8%;
    background:#0f172a;
    position:sticky;
    top:0;
}

.logo{
    color:#fff;
    font-size:28px;
    font-weight:bold;
}

.nav-links{
    display:flex;
    list-style:none;
}

.nav-links li{
    margin-left:25px;
}

.nav-links a{
    text-decoration:none;
    color:white;
    font-weight:500;
    transition:0.3s;
}

.nav-links a:hover{
    color:#38bdf8;
}

/* Hero Section */
.hero{
    height:90vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    background:linear-gradient(135deg,#2563eb,#06b6d4);
    color:white;
    padding:20px;
}

.hero-content h1{
    font-size:60px;
    margin-bottom:20px;
}

.hero-content p{
    font-size:20px;
    max-width:700px;
    margin:auto;
    margin-bottom:25px;
}

.btn{
    background:white;
    color:#2563eb;
    padding:14px 30px;
    border:none;
    border-radius:30px;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    transition:0.3s;
}

.btn:hover{
    transform:scale(1.05);
}

/* Features */
.features{
    padding:80px 8%;
    text-align:center;
}

.features h2{
    font-size:40px;
    color:#0f172a;
    margin-bottom:15px;
}

.features p{
    margin-bottom:40px;
}

.feature-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-10px);
}

.card h3{
    color:#2563eb;
    margin-bottom:15px;
}

/* Process */
.process{
    background:#e0f2fe;
    padding:80px 8%;
    text-align:center;
}

.process h2{
    margin-bottom:40px;
    color:#0f172a;
}

.steps{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:20px;
}

.step{
    background:white;
    padding:20px;
    border-radius:10px;
    width:220px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

/* Contact */
.contact{
    padding:80px 8%;
    text-align:center;
}

.contact h2{
    margin-bottom:20px;
}

.contact form{
    max-width:600px;
    margin:auto;
}

.contact input,
.contact textarea{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:8px;
}

.contact button{
    background:#2563eb;
    color:white;
    border:none;
    padding:12px 25px;
    border-radius:8px;
    cursor:pointer;
}

/* Footer */
footer{
    background:#0f172a;
    color:white;
    text-align:center;
    padding:20px;
}

/* Responsive */
@media(max-width:768px){

.hero-content h1{
    font-size:38px;
}

.hero-content p{
    font-size:16px;
}

.navbar{
    flex-direction:column;
}

.nav-links{
    margin-top:15px;
}

.nav-links li{
    margin:0 10px;
}

.steps{
    flex-direction:column;
    align-items:center;
}
}
</style>

</head>
<body>

<!-- Navbar -->
<nav class="navbar">
    <div class="logo">UI Redesign</div>
    <ul class="nav-links">
        <li><a href="#home">Home</a></li>
        <li><a href="#features">Features</a></li>
        <li><a href="#process">Process</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</nav>

<!-- Hero Section -->
<section class="hero" id="home">
    <div class="hero-content">
        <h1>Website UI Redesign</h1>
        <p>
            Transforming outdated websites into modern, user-friendly,
            and responsive digital experiences with improved usability
            and visual appeal.
        </p>
        <button class="btn">Explore Design</button>
    </div>
</section>

<!-- Features -->
<section class="features" id="features">
    <h2>Key Features</h2>
    <p>Enhancing user experience through modern design principles.</p>

    <div class="feature-grid">

        <div class="card">
            <h3>🔍 Heuristic Evaluation</h3>
            <p>Identify usability issues and improve website efficiency.</p>
        </div>

        <div class="card">
            <h3>🎨 Mood Boards</h3>
            <p>Create attractive visual concepts and branding styles.</p>
        </div>

        <div class="card">
            <h3>📱 Responsive Design</h3>
            <p>Optimized layouts for desktop, tablet, and mobile devices.</p>
        </div>

        <div class="card">
            <h3>🖥 High-Fidelity Mockups</h3>
            <p>Professional UI screens with modern visual hierarchy.</p>
        </div>

    </div>
</section>

<!-- Process -->
<section class="process" id="process">
    <h2>Design Process</h2>

    <div class="steps">
        <div class="step">1️⃣ Website Analysis</div>
        <div class="step">2️⃣ Heuristic Evaluation</div>
        <div class="step">3️⃣ Mood Board Creation</div>
        <div class="step">4️⃣ Style Guide Design</div>
        <div class="step">5️⃣ High-Fidelity Mockups</div>
        <div class="step">6️⃣ Responsive Testing</div>
    </div>
</section>

<!-- Contact -->
<section class="contact" id="contact">
    <h2>Contact Us</h2>

    <form>
        <input type="text" placeholder="Enter Your Name">
        <input type="email" placeholder="Enter Your Email">
        <textarea rows="5" placeholder="Your Message"></textarea>
        <button type="submit">Send Message</button>
    </form>
</section>

<!-- Footer -->
<footer>
    <p>© 2026 Website UI Redesign Project | Designed with HTML & CSS</p>
</footer>

</body>
</html>
