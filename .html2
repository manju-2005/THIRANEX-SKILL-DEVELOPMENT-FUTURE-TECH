<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mobile App Wireframe Project</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#eef2f7;
    padding:30px;
    display:flex;
    flex-wrap:wrap;
    gap:30px;
    justify-content:center;
}

.phone{
    width:320px;
    height:650px;
    background:white;
    border:8px solid #222;
    border-radius:30px;
    overflow:hidden;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

.title{
    text-align:center;
    padding:10px;
    background:#333;
    color:white;
    font-size:14px;
}

/* Common */
.header{
    padding:15px;
    background:#f2f2f2;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.circle{
    width:40px;
    height:40px;
    border-radius:50%;
    background:#ccc;
}

.search{
    margin:15px;
    height:40px;
    background:#e5e5e5;
    border-radius:8px;
}

.banner{
    margin:15px;
    height:140px;
    border-radius:10px;
    overflow:hidden;
}

.banner img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:10px;
    padding:15px;
}

.card{
    height:120px;
    border-radius:10px;
    overflow:hidden;
}

.card img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.profile{
    text-align:center;
    padding:20px;
}

.profile img{
    width:100px;
    height:100px;
    border-radius:50%;
    margin-bottom:15px;
}

.list{
    padding:15px;
}

.item{
    height:60px;
    background:#f2f2f2;
    margin-bottom:10px;
    border-radius:8px;
}

.bottom{
    position:absolute;
    bottom:0;
    width:100%;
}

.phone-inner{
    position:relative;
    height:100%;
}
</style>
</head>

<body>

<!-- LOGIN SCREEN -->
<div>
<div class="title">Login Screen</div>
<div class="phone">
<div class="phone-inner">

<div class="profile">
<img src="https://picsum.photos/200?random=1">
<h2>Welcome Back</h2>
</div>

<div class="search"></div>
<div class="search"></div>

<div style="margin:20px;height:50px;background:#bdbdbd;border-radius:10px;"></div>

</div>
</div>
</div>

<!-- HOME SCREEN -->
<div>
<div class="title">Home Dashboard</div>
<div class="phone">
<div class="phone-inner">

<div class="header">
<div class="circle"></div>
<div class="circle"></div>
</div>

<div class="search"></div>

<div class="banner">
<img src="https://picsum.photos/400/200?random=2">
</div>

<div class="grid">
<div class="card"><img src="https://picsum.photos/200?random=3"></div>
<div class="card"><img src="https://picsum.photos/200?random=4"></div>
<div class="card"><img src="https://picsum.photos/200?random=5"></div>
<div class="card"><img src="https://picsum.photos/200?random=6"></div>
</div>

</div>
</div>
</div>

<!-- PRODUCT SCREEN -->
<div>
<div class="title">Product Screen</div>
<div class="phone">
<div class="phone-inner">

<div class="banner">
<img src="https://picsum.photos/400/300?random=7">
</div>

<div style="padding:15px;">
<h3>Product Name</h3>
<p>⭐⭐⭐⭐⭐</p>
<p>Lorem ipsum product description.</p>
</div>

<div class="grid">
<div class="card"><img src="https://picsum.photos/200?random=8"></div>
<div class="card"><img src="https://picsum.photos/200?random=9"></div>
</div>

</div>
</div>
</div>

<!-- PROFILE SCREEN -->
<div>
<div class="title">Profile Screen</div>
<div class="phone">
<div class="phone-inner">

<div class="profile">
<img src="https://picsum.photos/200?random=10">
<h2>John Doe</h2>
<p>UI/UX Designer</p>
</div>

<div class="list">
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
</div>

</div>
</div>
</div>

<!-- NOTIFICATION SCREEN -->
<div>
<div class="title">Notifications</div>
<div class="phone">
<div class="phone-inner">

<div class="header">
<h3>Notifications</h3>
</div>

<div class="list">
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
</div>

</div>
</div>
</div>

<!-- SETTINGS SCREEN -->
<div>
<div class="title">Settings</div>
<div class="phone">
<div class="phone-inner">

<div class="header">
<h3>Settings</h3>
</div>

<div class="list">
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
<div class="item"></div>
</div>

</div>
</div>
</div>

</body>
</html>
