<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Interactive Prototype</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#e8eef7;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.phone{
    width:360px;
    height:720px;
    background:white;
    border-radius:35px;
    overflow:hidden;
    border:10px solid #222;
    box-shadow:0 10px 30px rgba(0,0,0,0.2);
    position:relative;
}

.screen{
    width:100%;
    height:100%;
    position:absolute;
    top:0;
    left:100%;
    transition:0.5s ease;
    background:white;
}

.active{
    left:0;
}

.center{
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    height:100%;
    padding:20px;
    text-align:center;
}

button{
    padding:12px 25px;
    border:none;
    background:#2563eb;
    color:white;
    border-radius:8px;
    cursor:pointer;
    margin-top:15px;
}

input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:8px;
}

.header{
    background:#2563eb;
    color:white;
    padding:18px;
    text-align:center;
}

.banner img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.cards{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
    padding:15px;
}

.card{
    background:#f4f4f4;
    border-radius:10px;
    overflow:hidden;
    cursor:pointer;
    transition:0.3s;
}

.card:hover{
    transform:scale(1.03);
}

.card img{
    width:100%;
    height:120px;
    object-fit:cover;
}

.card p{
    padding:10px;
    text-align:center;
}

.profile{
    text-align:center;
    padding:30px;
}

.profile img{
    width:120px;
    height:120px;
    border-radius:50%;
    margin-bottom:15px;
}

.back{
    background:#555;
}
</style>
</head>

<body>

<div class="phone">

    <!-- Splash Screen -->
    <div class="screen active" id="splash">
        <div class="center">
            <img src="https://picsum.photos/200/200" width="150">
            <h1>MyApp</h1>
            <button onclick="showScreen('login')">Start</button>
        </div>
    </div>

    <!-- Login -->
    <div class="screen" id="login">
        <div class="center">
            <h2>Login</h2>

            <input type="email" placeholder="Email">
            <input type="password" placeholder="Password">

            <button onclick="showScreen('home')">Login</button>
        </div>
    </div>

    <!-- Home -->
    <div class="screen" id="home">
        <div class="header">Home Dashboard</div>

        <div class="banner">
            <img src="https://picsum.photos/400/200?random=1">
        </div>

        <div class="cards">

            <div class="card" onclick="showScreen('product')">
                <img src="https://picsum.photos/200?random=2">
                <p>Product 1</p>
            </div>

            <div class="card" onclick="showScreen('product')">
                <img src="https://picsum.photos/200?random=3">
                <p>Product 2</p>
            </div>

            <div class="card" onclick="showScreen('product')">
                <img src="https://picsum.photos/200?random=4">
                <p>Product 3</p>
            </div>

            <div class="card" onclick="showScreen('profile')">
                <img src="https://picsum.photos/200?random=5">
                <p>Profile</p>
            </div>

        </div>
    </div>

    <!-- Product -->
    <div class="screen" id="product">
        <div class="header">Product Details</div>

        <img src="https://picsum.photos/400/300?random=6"
             style="width:100%;height:250px;object-fit:cover;">

        <div style="padding:20px">
            <h2>Smart Product</h2>
            <p>⭐⭐⭐⭐⭐</p>
            <br>
            <p>
                This screen demonstrates a clickable
                product page in an interactive prototype.
            </p>

            <button>Add to Cart</button>
            <button class="back"
                    onclick="showScreen('home')">
                    Back
            </button>
        </div>
    </div>

    <!-- Profile -->
    <div class="screen" id="profile">

        <div class="header">User Profile</div>

        <div class="profile">

            <img src="https://picsum.photos/200?random=7">

            <h2>John Doe</h2>
            <p>UI/UX Designer</p>

            <br>

            <button>Edit Profile</button>

            <button class="back"
                    onclick="showScreen('home')">
                    Back
            </button>

        </div>
    </div>

</div>

<script>
function showScreen(screenId){

    let screens=document.querySelectorAll('.screen');

    screens.forEach(screen=>{
        screen.classList.remove('active');
    });

    document.getElementById(screenId)
            .classList.add('active');
}
</script>

</body>
</html>
